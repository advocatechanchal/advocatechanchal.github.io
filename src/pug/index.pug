doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='Advocate Chanchal Bhati legal services in Surajpur Court, Greater Noida.')
        meta(name='author', content='Advocate Chanchal Bhati')

        title Advocate Chanchal Bhati | Legal Services | Surajpur Court

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Font Awesome icons (free version)
        script(src='https://use.fontawesome.com/releases/v6.3.0/js/all.js', crossorigin='anonymous')

        // Google fonts
        link(href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap', rel='stylesheet', type='text/css')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css', rel='stylesheet')

    body#page-top

        // Navigation
        nav#mainNav.navbar.navbar-expand-lg.navbar-dark.fixed-top
            .container
                a.navbar-brand(href='#page-top')
                    span Advocate Chanchal Bhati
                button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    | Menu
                    i.fas.fa-bars.ms-1
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.text-uppercase.ms-auto.py-4.py-lg-0
                        li.nav-item
                            a.nav-link(href='#services') Expertise
                        li.nav-item
                            a.nav-link(href='#portfolio') Focus Areas
                        li.nav-item
                            a.nav-link(href='#about') Journey
                        li.nav-item
                            a.nav-link(href='#team') Advocate
                        li.nav-item
                            a.nav-link(href='#contact') Contact

        // Masthead
        header.masthead
            .container
                .masthead-subheading Legal Representation With Clarity, Commitment, and Courtroom Discipline
                .masthead-heading Advocate Chanchal Bhati
                p.lead.masthead-brief
                    | Practicing across legal matters with active work at Surajpur Court, Greater Noida.
                    |  Focused on practical legal strategy, documentation rigor, and steady client communication.
                a.btn.btn-primary.btn-xl.text-uppercase(href='#services') Explore Services
                a.btn.btn-outline-light.btn-xl.text-uppercase.ms-lg-3.mt-3.mt-lg-0(href='#contact') Book A Consultation

        // Expertise
        section#services.page-section
            .container
                .text-center
                    h2.section-heading.text-uppercase Legal Expertise
                    h3.section-subheading.text-muted Strategic legal support tailored to civil, criminal, family, and property-related concerns.
                .row.text-center
                    .col-md-4
                        span.fa-stack.fa-4x
                            i.fas.fa-circle.fa-stack-2x.text-primary
                            i.fas.fa-scale-balanced.fa-stack-1x.fa-inverse
                        h4.my-3 Litigation & Court Representation
                        p.text-muted
                            | Drafting, appearances, pleadings, and procedural follow-through for court-led matters with a strong emphasis on preparation.
                    .col-md-4
                        span.fa-stack.fa-4x
                            i.fas.fa-circle.fa-stack-2x.text-primary
                            i.fas.fa-file-signature.fa-stack-1x.fa-inverse
                        h4.my-3 Documentation & Legal Drafting
                        p.text-muted
                            | Agreements, replies, notices, applications, and supporting legal paperwork prepared with precision and legal intent.
                    .col-md-4
                        span.fa-stack.fa-4x
                            i.fas.fa-circle.fa-stack-2x.text-primary
                            i.fas.fa-handshake-angle.fa-stack-1x.fa-inverse
                        h4.my-3 Consultation & Case Strategy
                        p.text-muted
                            | Honest preliminary review, case positioning, and next-step guidance for clients seeking practical legal direction.

        // Focus Areas
        section#portfolio.page-section.bg-light
            .container
                .text-center
                    h2.section-heading.text-uppercase Practice Focus Areas
                    h3.section-subheading.text-muted Core legal domains handled through structured advice, drafting, and representation.
                .row
                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            a.portfolio-link(data-bs-toggle='modal', href='#portfolioModal1')
                                .portfolio-hover
                                    .portfolio-hover-content
                                        i.fas.fa-arrow-up-right-from-square.fa-2x
                                img.img-fluid(src='assets/img/portfolio/1.jpg', alt='...')
                            .portfolio-caption
                                .portfolio-caption-heading Civil Disputes
                                .portfolio-caption-subheading.text-muted Recovery suits, injunctions, and procedural civil litigation.
                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            a.portfolio-link(data-bs-toggle='modal', href='#portfolioModal2')
                                .portfolio-hover
                                    .portfolio-hover-content
                                        i.fas.fa-arrow-up-right-from-square.fa-2x
                                img.img-fluid(src='assets/img/portfolio/2.jpg', alt='...')
                            .portfolio-caption
                                .portfolio-caption-heading Criminal Matters
                                .portfolio-caption-subheading.text-muted Bail, complaints, defense support, and court coordination.
                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            a.portfolio-link(data-bs-toggle='modal', href='#portfolioModal3')
                                .portfolio-hover
                                    .portfolio-hover-content
                                        i.fas.fa-arrow-up-right-from-square.fa-2x
                                img.img-fluid(src='assets/img/portfolio/3.jpg', alt='...')
                            .portfolio-caption
                                .portfolio-caption-heading Family Law
                                .portfolio-caption-subheading.text-muted Matrimonial disputes, maintenance, custody, and settlement pathways.
                    .col-lg-4.col-sm-6.mb-4.mb-lg-0
                        .portfolio-item
                            a.portfolio-link(data-bs-toggle='modal', href='#portfolioModal4')
                                .portfolio-hover
                                    .portfolio-hover-content
                                        i.fas.fa-arrow-up-right-from-square.fa-2x
                                img.img-fluid(src='assets/img/portfolio/4.jpg', alt='...')
                            .portfolio-caption
                                .portfolio-caption-heading Property Matters
                                .portfolio-caption-subheading.text-muted Documentation checks, title concerns, and possession-related disputes.
                    .col-lg-4.col-sm-6.mb-4.mb-sm-0
                        .portfolio-item
                            a.portfolio-link(data-bs-toggle='modal', href='#portfolioModal5')
                                .portfolio-hover
                                    .portfolio-hover-content
                                        i.fas.fa-arrow-up-right-from-square.fa-2x
                                img.img-fluid(src='assets/img/portfolio/5.jpg', alt='...')
                            .portfolio-caption
                                .portfolio-caption-heading Consumer & Financial Claims
                                .portfolio-caption-subheading.text-muted Complaint drafting and representation in consumer and payment disputes.
                    .col-lg-4.col-sm-6
                        .portfolio-item
                            a.portfolio-link(data-bs-toggle='modal', href='#portfolioModal6')
                                .portfolio-hover
                                    .portfolio-hover-content
                                        i.fas.fa-arrow-up-right-from-square.fa-2x
                                img.img-fluid(src='assets/img/portfolio/6.jpg', alt='...')
                            .portfolio-caption
                                .portfolio-caption-heading Legal Notices & Replies
                                .portfolio-caption-subheading.text-muted Timely notice drafting and response management before escalation.

        // Journey
        section#about.page-section
            .container
                .text-center
                    h2.section-heading.text-uppercase Professional Journey
                    h3.section-subheading.text-muted A methodical workflow designed to keep clients informed and legally prepared at every stage.
                ul.timeline
                    li
                        .timeline-image
                            img.rounded-circle.img-fluid(src='assets/img/about/1.jpg', alt='Initial Consultation')
                        .timeline-panel
                            .timeline-heading
                                h4 Step 01
                                h4.subheading Consultation & Matter Review
                            .timeline-body
                                p.text-muted
                                    | Your concern is understood with facts, documents, chronology, and immediate legal implications.
                    li.timeline-inverted
                        .timeline-image
                            img.rounded-circle.img-fluid(src='assets/img/about/2.jpg', alt='Legal Planning')
                        .timeline-panel
                            .timeline-heading
                                h4 Step 02
                                h4.subheading Strategy & Documentation
                            .timeline-body
                                p.text-muted
                                    | A clear legal path is defined with drafting, compliance checks, and filing readiness.
                    li
                        .timeline-image
                            img.rounded-circle.img-fluid(src='assets/img/about/3.jpg', alt='Court Representation')
                        .timeline-panel
                            .timeline-heading
                                h4 Step 03
                                h4.subheading Representation & Hearings
                            .timeline-body
                                p.text-muted
                                    | Active follow-up for hearings, arguments, procedural updates, and court communication.
                    li.timeline-inverted
                        .timeline-image
                            img.rounded-circle.img-fluid(src='assets/img/about/4.jpg', alt='Resolution Support')
                        .timeline-panel
                            .timeline-heading
                                h4 Step 04
                                h4.subheading Resolution & Next Action
                            .timeline-body
                                p.text-muted
                                    | Orders, compliance steps, and post-order remedies are tracked for practical closure.
                    li.timeline-inverted
                        .timeline-image
                            h4
                                | Your
                                br
                                | Matter
                                br
                                | First

        // Advocate
        section#team.page-section.bg-light
            .container
                .text-center
                    h2.section-heading.text-uppercase Advocate Profile
                    h3.section-subheading.text-muted Grounded, responsive, and committed to practical legal outcomes.
                .row
                    .col-lg-4.mx-auto
                        .team-member
                            img.mx-auto.rounded-circle(src='assets/img/team/1.jpg', alt='...')
                            h4 Advocate Chanchal Bhati
                            p.text-muted Legal Practitioner | Surajpur Court, Greater Noida
                            a.btn.btn-dark.btn-social.mx-2(href='#contact', aria-label='Book consultation')
                                i.fas.fa-calendar-check
                            a.btn.btn-dark.btn-social.mx-2(href='#services', aria-label='View practice areas')
                                i.fas.fa-gavel
                            a.btn.btn-dark.btn-social.mx-2(href='#about', aria-label='Know the process')
                                i.fab.fa-linkedin-in
                .row
                    .col-lg-8.mx-auto.text-center
                        p.large.text-muted
                            | Clear communication, disciplined preparation, and professional representation remain at the center of every matter.

        // Coverage
        div.py-5
            .container
                .text-center.mb-4
                    h3.section-subheading.text-muted Court and legal forum readiness
                .row.align-items-center
                    .col-md-3.col-sm-6.my-3
                        .coverage-badge District Court Work
                    .col-md-3.col-sm-6.my-3
                        .coverage-badge Civil Proceedings
                    .col-md-3.col-sm-6.my-3
                        .coverage-badge Criminal Proceedings
                    .col-md-3.col-sm-6.my-3
                        .coverage-badge Family Matters

        // Contact
        section#contact.page-section
            .container
                .text-center
                    h2.section-heading.text-uppercase Contact & Consultation
                    h3.section-subheading.text-muted Please share your details and matter summary. Profile address/contact/email are intentionally left blank.
                .row.g-4.align-items-stretch
                    .col-lg-7
                        form#contactForm
                            .row.g-3
                                .col-md-6
                                    input#name.form-control(type='text', placeholder='Your Name')
                                .col-md-6
                                    input#phone.form-control(type='tel', placeholder='Your Phone')
                                .col-12
                                    textarea#message.form-control(rows='7', placeholder='Briefly describe your legal matter')
                                .col-12.text-start
                                    button.btn.btn-primary.btn-xl.text-uppercase(type='submit') Request Call Back
                    .col-lg-5
                        .contact-detail-card
                            h4.text-uppercase Advocate Profile Fields
                            .detail-row
                                span.label Address
                                span.value
                            .detail-row
                                span.label Contact
                                span.value
                            .detail-row
                                span.label Email
                                span.value
                            p.small.text-muted.mt-4
                                | These fields are intentionally blank and ready for you to update after deployment.

        // Footer
        footer.footer.py-4
            .container
                .row.align-items-center
                    .col-lg-4.text-lg-start
                        | Copyright © Advocate Chanchal Bhati 2026
                    .col-lg-4.my-3.my-lg-0.text-center
                        span.footer-tagline Surajpur Court | Greater Noida
                    .col-lg-4.text-lg-end
                        a.link-dark.text-decoration-none.me-3(href='#services') Practice Areas
                        a.link-dark.text-decoration-none(href='#contact') Consultation

        // Portfolio Modals
        include includes/portfolio-modal-1
        include includes/portfolio-modal-2
        include includes/portfolio-modal-3
        include includes/portfolio-modal-4
        include includes/portfolio-modal-5
        include includes/portfolio-modal-6

        // Bootstrap core JS
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js')

        // Core theme JS
        script(src='js/scripts.js')
