// Portfolio item 2 modal popup
#portfolioModal2.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase Criminal Matters
                            p.item-intro.text-muted Responsive legal action with procedural discipline.
                            img.img-fluid.d-block.mx-auto(src='assets/img/portfolio/2.jpg', alt='...')
                            p Support for bail applications, criminal complaints, legal responses, and hearing coordination with client guidance on each critical step.
                            ul.list-inline
                                li
                                    strong Representation:
                                    | Drafting and hearing preparation
                                li
                                    strong Focus:
                                    | Criminal court proceedings
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                | Close Details