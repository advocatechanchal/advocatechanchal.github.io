        script(src='https://cdn.startbootstrap.com/sb-forms-latest.js')
    script.
        // Typing animation for header
        document.addEventListener('DOMContentLoaded', function () {
            var text = 'Simple, powerful ideas that brings communities closer.';
            var el = document.getElementById('typed-text');
            if (el) {
                el.textContent = '';
                var i = 0;
                
                function type() {
                    if (i < text.length) {
                        el.textContent += text.charAt(i);
                        i++;
                        setTimeout(type, 100);
                    }
                }
                setTimeout(type, 1000);
            }
            
            // Scroll-triggered service animation
            function checkScroll() {
                var servicesSection = document.getElementById('services');
                var serviceSteps = document.querySelectorAll('.service-step');
                
                if (servicesSection && serviceSteps.length > 0) {
                    var rect = servicesSection.getBoundingClientRect();
                    var windowHeight = window.innerHeight;
                    
                    // Check if services section is in view
                    if (rect.top < windowHeight * 0.8) {
                        serviceSteps.forEach(function(step, index) {
                            setTimeout(function() {
                                step.classList.add('animate');
                            }, index * 500); // 500ms delay between each step
                        });
                        
                        // Remove scroll listener after animation starts
                        window.removeEventListener('scroll', checkScroll);
                    }
                }
            }
            
            // Listen for scroll events
            window.addEventListener('scroll', checkScroll);
            
            // Check on load in case services is already in view
            checkScroll();
        });
